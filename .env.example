# Copy to .env.local and fill in values. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: secures GET /api/cron/publish-scheduled-blog-posts if you call it from an external
# scheduler (or Vercel Cron on a paid plan). Scheduled posts also release when /blog or CEO Blog loads.
# CRON_SECRET=

# Bootstrap sign-in: users can type EITHER the same value as AUTH_BOOTSTRAP_LOGIN_ID OR the same email as AUTH_BOOTSTRAP_EMAIL.
# Password is always checked by Supabase for AUTH_BOOTSTRAP_EMAIL.
AUTH_BOOTSTRAP_LOGIN_ID=
AUTH_BOOTSTRAP_EMAIL=you@example.com
# Set to true to skip SMS 2FA (recommended for solo admin / until Twilio is wired).
AUTH_BOOTSTRAP_SKIP_2FA=true

# Optional: allow any Supabase user to sign in by typing their email as Login ID (no profiles.login_id required).
AUTH_ALLOW_EMAIL_SIGNIN=false

# SMS 2FA (required in production unless AUTH_BOOTSTRAP_SKIP_2FA is true for all users)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public site URL (canonical links, analytics embed hints)
NEXT_PUBLIC_SITE_URL=

# Schedule CTAs (Book a call, pricing Lead Machine, growth-system funnel): Calendly event URL when set; else `/book-call`.
# NEXT_PUBLIC_CALENDLY_EVENT_URL=https://calendly.com/your-handle/discovery

# First-party analytics: write_key from analytics_site_keys (N-Tech company). After migration 019 the
# seeded key matches this value — rotate in Supabase + Vercel if you treat it as public knowledge.
NEXT_PUBLIC_ANALYTICS_WRITE_KEY=ntech_sk_b335cf53698b75b45107f050ec8312c9

# Groq (site chat — https://console.groq.com/keys)
GROQ_API_KEY=
# Optional — defaults to llama-3.3-70b-versatile
# GROQ_MODEL=
# Optional — overrides default assistant system prompt in src/lib/chat-config.ts
# CHAT_SYSTEM_PROMPT=

# CEO dashboard Groq assistant ( /api/dashboard-assistant/chat — requires signed-in user )
# Optional IANA timezone for "today" in the assistant context (default America/Chicago)
# DASHBOARD_ASSISTANT_TIMEZONE=America/Chicago
# Optional — full override of dashboard assistant system prompt (see src/lib/dashboard-assistant-config.ts)
# DASHBOARD_ASSISTANT_SYSTEM_PROMPT=
