# Copy to .env.local and fill in values. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: map a login ID to a Supabase Auth email (password is checked by Supabase only).
# 1) Create the user in Supabase (Auth) with the same email and your chosen password.
# 2) Ensure public.profiles has a row for that user (id = auth user id) and login_id if you use the normal flow.
# 3) For bootstrap sign-in: set login_id here to match the ID users type at login.
AUTH_BOOTSTRAP_LOGIN_ID=
AUTH_BOOTSTRAP_EMAIL=you@example.com
# Set to true to skip SMS 2FA for this account (recommended for solo admin; use 2FA in production when possible).
AUTH_BOOTSTRAP_SKIP_2FA=true

# SMS 2FA (required in production unless AUTH_BOOTSTRAP_SKIP_2FA is true for all users)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
